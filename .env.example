# ──────────────────────────────────────────────
# arxiv-sentinel configuration
# Copy to .env and fill in secrets before use.
# ──────────────────────────────────────────────

# Application
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
SERVICE_NAME=arxiv-sentinel

# ── Database (PostgreSQL) ────────────────────
DB_URL=postgresql+psycopg2://sentinel:sentinel@postgres:5432/sentinel_db
DB_ECHO=false
DB_POOL_SIZE=20
DB_OVERFLOW=0

# ── Search engine (OpenSearch) ───────────────
SEARCH__HOST=http://opensearch:9200
SEARCH__INDEX=arxiv-papers
SEARCH__CHUNK_SUFFIX=-chunks
SEARCH__MAX_TEXT_BYTES=1000000
SEARCH__VECTOR_DIM=1024
SEARCH__SPACE_TYPE=cosinesimil
SEARCH__RRF_PIPELINE=hybrid-rrf-pipeline
SEARCH__HYBRID_MULTIPLIER=2

# ── LLM inference (Ollama) ──────────────────
LLM__HOST=http://ollama:11434
LLM__MODEL=llama3.2:1b
LLM__TIMEOUT=300

# ── Embeddings (Jina AI) ────────────────────
JINA_API_KEY=your_jina_api_key_here

# ── arXiv ingestion ─────────────────────────
ARXIV__MAX_PAPERS=15
ARXIV__API_URL=https://export.arxiv.org/api/query
ARXIV__PDF_DIR=./data/arxiv_pdfs
ARXIV__RATE_DELAY=3.0
ARXIV__TIMEOUT=30
ARXIV__CATEGORY=cs.AI
ARXIV__RETRIES=3
ARXIV__RETRY_BASE=5.0
ARXIV__CONCURRENCY=5

# ── PDF parsing ──────────────────────────────
PDF__MAX_PAGES=30
PDF__MAX_SIZE_MB=20
PDF__OCR=false
PDF__TABLE_EXTRACT=true

# ── Text chunking ───────────────────────────
CHUNKING__SIZE=600
CHUNKING__OVERLAP=100
CHUNKING__MIN_SIZE=100
CHUNKING__SECTION_AWARE=true

# ── Cache (Redis) ───────────────────────────
CACHE__HOST=redis
CACHE__PORT=6379
CACHE__PASSWORD=
CACHE__DB=0
CACHE__TTL_HOURS=6

# ── Observability (Langfuse) ────────────────
TRACING__ENABLED=true
TRACING__HOST=http://localhost:3001
TRACING__PUBLIC_KEY=pk-lf-local-dev
TRACING__SECRET_KEY=sk-lf-local-dev
TRACING__FLUSH_AT=15
TRACING__FLUSH_INTERVAL=1.0
TRACING__DEBUG=true

# Langfuse infrastructure secrets
LANGFUSE_NEXTAUTH_SECRET=replace-with-32-char-random-string
LANGFUSE_SALT=replace-with-32-char-random-string
LANGFUSE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
LANGFUSE_REDIS_PASSWORD=langfuse_redis_pw
LANGFUSE_MINIO_ACCESS=langfuse_minio
LANGFUSE_MINIO_SECRET=langfuse_minio_secret

# ── Telegram bot ─────────────────────────────
TELEGRAM__ENABLED=false
TELEGRAM__TOKEN=your_telegram_bot_token_here

# ── Airflow ──────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true
AIRFLOW__HOME=/opt/airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://sentinel:sentinel@postgres:5432/sentinel_db
